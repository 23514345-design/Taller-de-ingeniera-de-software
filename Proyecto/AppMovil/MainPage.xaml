<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppMovil.MainPage"
             BackgroundColor="#121212">

    <StackLayout Padding="20" Spacing="15">

        <Label Text="Estado del Bastón"
               FontSize="26"
               TextColor="White"
               HorizontalOptions="Center" />

        <Frame BackgroundColor="#1E1E1E"
               CornerRadius="10"
               Padding="10">

            <ListView ItemsSource="{Binding Alertas}"
                      SeparatorVisibility="None">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <Frame Margin="5"
                                   Padding="10"
                                   CornerRadius="8"
                                   BackgroundColor="#2A2A2A">

                                <StackLayout>
                                    <Label Text="{Binding Mensaje}"
                                           FontAttributes="Bold"
                                           TextColor="White" />

                                    <Label Text="{Binding Distancia, StringFormat='Distancia: {0} cm'}"
                                           TextColor="LightGray" />
                                </StackLayout>

                            </Frame>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>
        </Frame>

    </StackLayout>
</ContentPage>
